#!/usr/bin/make -f

# Patch for JIconFont-FontAwesome 4.7.0.1
JICONFONT_FONT_AWESOME_VERSION=$(shell dpkg -s libjiconfont-font-awesome-java | grep -oP "(?<=^Version: ).+")
ifeq ($(findstring 4.7.0.0,$(JICONFONT_FONT_AWESOME_VERSION)),)
export QUILT_PATCH_DIR:=debian/patches-Debian_12
endif

export JAVA_HOME=$(shell readlink -f /usr/bin/javac | sed "s:/bin/javac::")

ANT_OPTIONS=-f $(CURDIR)/linux/build.xml -Dno-ivy=true -Dno-submodule=true

%:
	dh $@ --with javahelper,quilt --buildsystem=ant

override_dh_auto_build:
	dh_auto_build -- $(ANT_OPTIONS) jar

override_dh_auto_clean:
	dh_auto_clean -- $(ANT_OPTIONS) clean

override_dh_auto_install:
	install -Dt debian/lightzone/usr/bin lightcrafts/products/dcraw_lzr
	install -t  debian/lightzone/usr/bin linux/products/lightzone
	install -Dt debian/lightzone/usr/lib/lightzone lightcrafts/products/*.so
	install -Dt debian/lightzone/usr/share/applications linux/products/lightzone.desktop -m644
	install -Dt debian/lightzone/usr/share/java/lightzone lightcrafts/lib/imagen-all-*.jar -m644
	install -t  debian/lightzone/usr/share/java/lightzone lightcrafts/products/lightcrafts.jar -m644
	install -t  debian/lightzone/usr/share/java/lightzone linux/products/lightcrafts-linux.jar -m644
	cp -pHR linux/icons debian/lightzone/usr/share
